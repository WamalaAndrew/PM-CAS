{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the PM-CAS application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "description": "The user's profile photo URL." },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "The user's role." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user was created." }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Assessment": {
      "title": "Assessment",
      "description": "A risk assessment generated by the system.",
      "type": "object",
      "properties": {
        "assessment_id": { "type": "string" },
        "applicant_name": { "type": "string" },
        "applicant_id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "credit_score": { "type": "number" },
        "decision": { "type": "string", "enum": ["APPROVE", "DENY", "REFER TO COMMITTEE"] },
        "risk_rating": { "type": "string", "enum": ["Low", "Moderate", "High", "Critical"] },
        "key_findings": { "type": "array", "items": { "type": "string" } },
        "mitigation_suggestion": { "type": "string" },
        "system_integrity_check": { "type": "string" },
        "uid": { "type": "string", "description": "The ID of the user who created this assessment." }
      },
      "required": ["assessment_id", "applicant_name", "applicant_id", "date", "credit_score", "decision", "risk_rating", "key_findings", "mitigation_suggestion", "system_integrity_check", "uid"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/assessments/{assessmentId}": {
      "schema": { "$ref": "#/entities/Assessment" },
      "description": "Stores risk assessments."
    }
  }
}
