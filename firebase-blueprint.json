{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the PM-CAS application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "description": "The user's profile photo URL." },
        "role": { "type": "string", "enum": ["admin", "loan_officer", "admin_assistant", "credit_analyst", "applicant"], "description": "The user's role." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user was created." },
        "phone": { "type": "string", "description": "The user's phone number." },
        "address": { "type": "string", "description": "The user's physical address." }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "LoanApplication": {
      "title": "Loan Application",
      "description": "A loan application submitted by an applicant.",
      "type": "object",
      "properties": {
        "loan_type": { "type": "string" },
        "loan_amount": { "type": "number" },
        "loan_purpose": { "type": "string" },
        "monthly_income": { "type": "number" },
        "savings_balance": { "type": "number" },
        "employment_tenure_months": { "type": "number" },
        "collateral_type": { "type": "string" },
        "collateral_value": { "type": "number" },
        "collateral_valuation_date": { "type": "string", "format": "date" },
        "collateral_location": { "type": "string" },
        "group_guarantee": { "type": "boolean" },
        "business_sector": { "type": "string" },
        "location": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "assessed", "approved", "denied"] },
        "applicant_id": { "type": "string" },
        "applicant_name": { "type": "string" },
        "applicant_email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "assessment_id": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["loan_type", "loan_amount", "loan_purpose", "monthly_income", "savings_balance", "employment_tenure_months", "collateral_type", "collateral_value", "collateral_valuation_date", "collateral_location", "group_guarantee", "business_sector", "location", "status", "applicant_id", "applicant_name", "applicant_email", "createdAt", "uid"]
    },
    "Task": {
      "title": "Task",
      "description": "A task for follow-up or action related to a loan application.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "applicationId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "dueDate": { "type": "string", "format": "date" },
        "assignedTo": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "applicationId", "title", "status", "assignedTo", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/assessments/{assessmentId}": {
      "schema": { "$ref": "#/entities/Assessment" },
      "description": "Stores risk assessments."
    },
    "/loanApplications/{applicationId}": {
      "schema": { "$ref": "#/entities/LoanApplication" },
      "description": "Stores loan applications."
    },
    "/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Stores tasks for loan officers."
    }
  }
}
